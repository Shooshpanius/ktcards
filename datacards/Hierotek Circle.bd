  "factionRules": [
    {
      "name": "Living Metal",
      "description": "The Necrons’ semi-sentient metal skin enables them to heal devastating damage in the midst of battle. In the Ready step of each Strategy phase, after resolving all other rules in this step (e.g. HIEROTEK CIRCLE operative regains up to D3+1 lost wounds (roll separately for each)."
    }
  ],
