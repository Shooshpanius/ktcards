  "factionRules": [
    {
      "name": "Burrow",
      "description": "Raveners will emerge from their tunnels to strike at unsuspecting victims, then disappear again before their foe can properly react. When setting up a RAVENER kill team before the battle, your first two operatives must be set up as normal. Each other friendly RAVENER operative thereafter can be set up underground: place it to one side instead of in the killzone. In the Firefight phase, friendly RAVENER operatives set up underground are activated and"
    },
    {
      "name": "Tunnel",
      "description": "Raveners dig extensive tunnel networks in the ground and foundations beneath their prey’s feet, enabling the Hive Mind’s elite creations to outmanoeuvre and ambush their prey. At the end of the Set Up Operatives step, place"
    },
    {
      "name": "Predatory Instincts",
      "description": "Seemingly driven by an all-consuming hunger, and with hyper-adapted reflexes, Raveners are deadly blurs of muscle, talons and fangs. During each friendly RAVENER operative’s activation, it can perform two Fight actions. Each friendly RAVENER operative can"
    },
    {
      "name": "Tary",
      "description": "game, when an underground activated, don’t be afraid to pass and leave them underground ainst most teams, your opponent ctivate less-important operatives when and where your Raveners will"
    }
  ],
  "markersTokens": [
    {
      "name": "Your Tunnel markers and the area between your",
      "description": ""
    },
    {
      "name": "Whenever a friendly RAVENER operative",
      "description": ""
    },
    {
      "name": "Distend Dorsal Sac Heightened Senses",
      "description": ""
    }
  ],
  "strategyPloys": [
    {
      "name": "Whipcord Emergence",
      "cpCost": 1,
      "description": "Whether lunging from a rubble-strewn entrance to their network of tunnels or bursting forth in a shower of debris to snatch at prey, Raveners can surprise even elite sentinels. Whenever an operative is shooting a friendly RAVENER operative: • If that friendly operative has performed the Burrow action during that turning point, you can re-roll one of your defence dice. • If that friendly operative is on your TUNNEL, you can re-roll any of your defence dice."
    },
    {
      "name": "Tunnel Lurkers",
      "cpCost": 1,
      "description": "Raveners are horrifically adept at remaining all but invisible, partially submerged amidst broken terrain, until the moment they lunge. Whenever a friendly RAVENER operative is on your TUNNEL it’s in cover, unless it’s within 2\" of the active operative. Treat this as cover provided by Light terrain (therefore it’s affected by rules that prevent this, e.g. Seek Light and Vantage terrain)."
    },
    {
      "name": "Writhe Out Of Sight",
      "cpCost": 1,
      "description": "Few organisms are as capable of slithering away into darkness in the blink of an eye as Raveners. The question then is, where did they go…? Select one friendly RAVENER operative in the killzone. That friendly operative can immediately perform a free Burrow action. If it’s within 2\" of your TUNNEL, it can immediately perform a free Fall Back or Reposition action before it does so."
    }
  ],
  "firefightPloys": [
    {
      "name": "Subterranean Horror",
      "cpCost": 1,
      "description": "Those who think to trap a Ravener by tackling it at its brood burrow invite only their own demise, as the bioform uses hidden tunnels to encircle its prey before striking from an unexpected angle. performing the Fight action and selects a friendly RAVENER operative on your TUNNEL to fight against. In the Resolve Attack Dice step of that sequence, you resolve the first attack dice (i.e. defender instead of attacker)."
    },
    {
      "name": "Death Frenzy",
      "cpCost": 1,
      "description": "Raveners can be compelled by the Hive Mind to fight in a last surge of biostimulated aggression, even as their own bodies fail. operative is incapacitated. Before that operative is removed from the killzone, inflict D3 damage on each enemy operative within its control range (roll separately for each). If that friendly operative is a VENOMSPITTER that’s currently benefitting from the effects of its Distend Dorsal Sac action, inflict 2D3 damage instead."
    },
    {
      "name": "Burrowing Strike",
      "cpCost": 1,
      "description": "The last sight for many operatives fighting Raveners is a blur of their own uniform as they disappear into the depths of a xenos burrow. operative performs the Burrow action. Before that operative is removed from the killzone, or after setting it up on your TUNNEL, inflict D3+1 damage on each enemy operative within its control range (roll separately for each). You cannot use this ploy in the Strategy phase, or during a FELLTALON operative’s activation or counteraction if it performs the Toxic Lunge action (and vice versa)."
    }
  ],
  "factionEquipment": [
    {
      "name": "Acid Blood",
      "epCost": 1,
      "description": "Corrosive viscera and caustic fluids spray from these creatures’ wounds. Whenever a friendly RAVENER operative is fighting or retaliating, whenever an attack dice inflicts damage on it, roll one D6: on a 5+, inflict 1 damage on the enemy operative in that sequence.",
      "restrictions": null
    },
    {
      "name": "Heightened Senses",
      "epCost": 1,
      "description": "Even burrowing, Raveners can detect enemy pheromones, esoteric energies and the whirr of servos, enabling them to land sudden ambushes. Once per battle, after rolling off to decide initiative, if a friendly RAVENER operative is underground and an enemy operative is within 5\" of your TUNNEL, you can re-roll your dice.",
      "restrictions": null
    },
    {
      "name": "Metamorphic Flesh",
      "epCost": 1,
      "description": "Some Raveners are reported to have recovered from injuries that should have been fatal, their flesh and chitin reknitting in rapid regeneration. Whenever a friendly RAVENER operative is activated, it regains up to D3 lost wounds. NOTES:",
      "restrictions": null
    }
  ]
}