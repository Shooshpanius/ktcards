  "factionRules": [
    {
      "name": "Obelisk Node Matrix",
      "description": "Obelisk nodes are concentrations of Necron technology, hubs of energy and data streams. Whether raised up from their sites of ancient burial, formed from restructured local matter or phased into place from a pocket dimension, these angular nodes can empower a Cryptek and their servants. Impelled into positions where they can connect in a matrix of power, they aid the Cryptek’s ambitions whilst hampering their foes. As a STRATEGIC GAMBIT in the first turning point,"
    }
  ],
  "markersTokens": [
    {
      "name": "Molecular",
      "description": ""
    },
    {
      "name": "Whenever a friendly CANOPTEK CIRCLE Obelisk Node marker",
      "description": ""
    },
    {
      "name": "Matrix Manipulator Awakened Obelisk",
      "description": ""
