  "factionRules": [
    {
      "name": "Frenzy",
      "description": "Fellgor Ravagers channel their pain into an animalistic frenzy, dismissing wounds and bursting with aggression.\n\nWhenever a friendly FELLGOR RAVAGER operative that doesn't have one of your Frenzy tokens would be incapacitated during the battle, it's not incapacitated and it gains one of your Frenzy tokens. All remaining attack dice are discarded (including yours if this operative is fighting or retaliating). If it has a Conceal order, change it to Engage.\n\nWhenever a friendly FELLGOR RAVAGER operative has one of your Frenzy tokens:\n• It's only incapacitated as detailed below.\n• It cannot have a Conceal order.\n• It's injured.\n• It cannot perform the Pick Up Marker, unique (excluding Sweeping Blow, see VANDAL) or mission actions (excluding Operate Hatch).\n• For the purpose of determining control of markers and areas of the killzone, treat its APL stat as 1. This takes precedence over any stat changes.\n\nA friendly FELLGOR RAVAGER operative that has one of your Frenzy tokens is incapacitated when one of the following is met:\n• Its activation or counteraction ends.\n• An enemy operative is fighting against or retaliating against it and your opponent strikes with a critical success.\n• An enemy operative is fighting against or retaliating against it and your opponent strikes it for a second time with a normal success.\n• An enemy operative is shooting it and Critical Dmg is inflicted on it.\n• The battle ends (resolve this before any victory conditions that resolve at the end of the battle).\n\nYour opponent treats a FELLGOR RAVAGER operative as being incapacitated (instead of when it would be incapacitated normally) when it gains one of your Frenzy tokens for the purposes of scoring VPs (e.g. kill op) and faction rules that require it to be incapacitated (e.g. HAND OF THE ARCHON Power From Pain, CHAOS CULT Mutation, etc.)."
    }
  ],
  "markersTokens": [
    {
      "name": "Frenzy token",
      "description": "Gained when a friendly FELLGOR RAVAGER operative would be incapacitated. The operative is not incapacitated but is injured, cannot have a Conceal order, and is subject to all Frenzy restrictions. The operative is incapacitated at end of activation, on a critical strike, second normal strike, or inflicted Critical Dmg from shooting."
    },
    {
      "name": "Gong Knell token",
      "description": "Placed on the Deathknell when it uses its Gong Knell action. Until the start of the Deathknell's next activation or until incapacitated, whenever an operative shoots it, improve its Save stat by 1 and ignore the Piercing weapon rule."
    },
    {
      "name": "Mantle of Darkness token",
      "description": "Placed on the Shaman when it uses Mantle of Darkness. Until the start of its next activation or incapacitated, friendly FELLGOR RAVAGER operatives within 3\" with a Conceal order in cover cannot be selected as a valid target (except within 2\")."
    },
    {
      "name": "Chaos Sigil token",
      "description": "Tracks use of the Chaos Sigil faction equipment. Once per turning point, when an operative shoots a friendly FELLGOR RAVAGER operative, you can worsen the Piercing weapon rule by 1 (Piercing 1 is ignored)."
    },
    {
      "name": "Brass Adornments token",
      "description": "Tracks once-per-battle use of the Brass Adornments equipment. Allows using Animalistic Fury and Wild Rage firefight ploys for 0CP each once per battle."
    },
    {
      "name": "Gore Marks token",
      "description": "Tracks use of the Gore Marks faction equipment. Once per turning point when fighting or retaliating: inflict 1 damage on that friendly operative and re-roll one attack die. If the result is a fail, inflict 1 additional damage."
    },
    {
      "name": "Pelting Firepower token",
      "description": "Used to track which friendly FELLGOR RAVAGER operatives have shot an enemy operative during a turning point, for the purposes of the Pelting Firepower strategy ploy."
    }
  ],
  "strategyPloys": [
    {
      "name": "Violent Temperament",
      "cpCost": 1,
      "description": "Whenever a friendly FELLGOR RAVAGER operative is fighting or retaliating, after rolling your attack dice, you can use this rule. If you do, you must re-roll all of your attack dice (you cannot only re-roll some)."
    },
    {
      "name": "Ambush",
      "cpCost": 1,
      "description": "Whenever a friendly FELLGOR RAVAGER operative is activated, if its order is changed from Conceal to Engage, it's ambushing for that activation. Whenever a friendly FELLGOR RAVAGER operative that's ambushing is fighting, you can retain one of your normal successes as a critical success instead. Note that an operative that has one of your Frenzy tokens cannot ambush."
    },
    {
      "name": "Pelting Firepower",
      "cpCost": 1,
      "description": "Whenever a friendly FELLGOR RAVAGER operative is shooting an enemy operative that's been shot by another friendly FELLGOR RAVAGER operative during this turning point, that first friendly operative's ranged weapons have the Ceaseless weapon rule; if the enemy operative has been shot by more than one other friendly FELLGOR RAVAGER operative during this turning point, that first friendly operative's ranged weapons have the Relentless weapon rule instead."
    },
    {
      "name": "Reckless Determination",
      "cpCost": 1,
      "description": "Whenever an enemy operative is shooting an expended friendly FELLGOR RAVAGER operative, if you cannot retain any cover saves, you can retain one of your defence dice as a normal success without rolling it (in addition to a cover save, if any)."
    }
  ],
  "firefightPloys": [
    {
      "name": "Ruthless Rampage",
      "cpCost": 1,
      "description": "Use this firefight ploy after a friendly FELLGOR RAVAGER operative performs the Fight action, if it's no longer within control range of enemy operatives. That friendly operative can immediately perform a free Charge action (even if it's already performed the Charge action during that activation), but cannot move more than 3\" during that action."
    },
    {
      "name": "Wild Rage",
      "cpCost": 1,
      "description": "Use this firefight ploy when a friendly FELLGOR RAVAGER operative is activated. Until the end of that operative's activation, add 1\" to its Move stat."
    },
    {
      "name": "Animalistic Fury",
      "cpCost": 1,
      "description": "Use this firefight ploy when a friendly FELLGOR RAVAGER operative is fighting or retaliating and you strike with a critical success. Inflict 1 additional damage with that strike."
    },
    {
      "name": "Bloodsense",
      "cpCost": 1,
      "description": "Use this firefight ploy during a friendly FELLGOR RAVAGER operative's activation, when it incapacitates an enemy operative within its control range. Select one other ready friendly FELLGOR RAVAGER operative that's visible to and within 3\" of the incapacitated enemy operative. When that first friendly operative is expended, you can activate that other friendly operative before your opponent activates. When that other operative is expended, your opponent then activates as normal."
    }
  ],
  "factionEquipment": [
    {
      "name": "Brass Adornments",
      "epCost": 1,
      "description": "Once per battle, you can use the Animalistic Fury and Wild Rage firefight ploys for 0CP each.",
      "restrictions": null
    },
    {
      "name": "Gore Marks",
      "epCost": 1,
      "description": "Once per turning point, when a friendly FELLGOR RAVAGER operative is fighting or retaliating, you can use this rule. If you do, inflict 1 damage on that friendly operative and re-roll one of your attack dice. If the result is a fail, inflict 1 additional damage on that friendly operative.",
      "restrictions": null
    },
    {
      "name": "Chaos Sigil",
      "epCost": 1,
      "description": "Once per turning point, when an operative is shooting a friendly FELLGOR RAVAGER operative, at the start of the Roll Defence Dice step, you can use this rule. If you do, worsen the x of the Piercing weapon rule by 1 (if any) until the end of that sequence. Note that Piercing 1 would therefore be ignored.",
