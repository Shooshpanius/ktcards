    {
      "name": "Frenzy token Gong Knell Mantle of",
      "description": ""
    },
    {
      "name": "Note this can be strikes from two different",
      "description": ""
    },
    {
      "name": "Chaos Sigil Brass Gore Marks",
      "description": ""
    },
    {
      "name": "Your opponent treats a FELLGOR RAVAGER",
      "description": ""
