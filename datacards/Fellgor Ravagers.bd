  "factionRules": [
    {
      "name": "Frenzy",
      "description": "Fellgor Ravagers channel their pain into an animalistic frenzy, dismissing wounds and bursting with aggression. Whenever a friendly FELLGOR RAVAGER operative that doesn’t have one of your Frenzy"
    }
  ],
