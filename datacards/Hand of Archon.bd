  "strategyPloys": [
    {
      "name": "From Darkness, Death",
      "cpCost": 1,
      "description": "Honour is an alien concept to the Drukhari. They make use of distraction and misdirection to butcher unsuspecting foes from the shadows. Whenever a friendly HAND OF THE ARCHON operative is activated, before you determine its order, you can select one enemy operative that friendly operative isn’t a valid target for. Until the end of that activation, the first time that friendly operative is shooting against or fighting against that enemy operative, you can retain one of your normal successes as a critical success instead."
    },
    {
      "name": "Denizens Of Night",
      "cpCost": 1,
      "description": "Hailing from Commorragh – the Dark City – the Drukhari are born and raised in shadow, and use it to conceal their movements. Whenever an enemy operative is shooting a friendly HAND OF THE ARCHON operative that’s more than 2\" from enemy operatives, if Heavy or Light terrain is intervening, or any part of that friendly operative’s base is underneath Vantage terrain, you can re-roll one of your defence dice."
    }
  ],
  "firefightPloys": [
    {
      "name": "Heinous Arrogance",
      "cpCost": 1,
      "description": "To the conceited Drukhari, all opponents are little more than vermin – to be ignored or exterminated. activate a friendly operative. You can skip that activation."
    },
    {
      "name": "Prey On The Wounded",
      "cpCost": 1,
      "description": "Drukhari are drawn to agony, seeking out the injured to land a killing blow. for a friendly HAND OF THE ARCHON operative, if it’s shooting against or fighting against a wounded enemy operative. You can re-roll any of your attack dice."
    }
  ],
  "factionEquipment": [
    {
      "name": "Toxin Coating",
      "epCost": 1,
      "description": "Drukhari raiders are known to coat their blades in venom, ensuring that even the slightest nick of blade against flesh is fatal. Up to twice per turning point, whenever a friendly HAND OF THE ARCHON operative is fighting or retaliating and you’re selecting a melee weapon, you can use this rule. If you do, until the end of that sequence, that operative’s melee weapon has the Lethal 5+ weapon rule. NOTES:",
      "restrictions": null
    },
    {
      "name": "Refined Poison",
      "epCost": 1,
      "description": "Splinter rounds are infused with exquisitely lethal concoctions distilled from the potent venoms and toxins of deadly flora and fauna. Up to twice per turning point, whenever a friendly HAND OF THE ARCHON operative is performing the Shoot action and you select a shardcarbine, splinter cannon, splinter pistol, splinter rifle or stinger pistol, you can use this rule. If you do, until the end of that action, add 1 to the Normal Dmg stat of that weapon. NOTES:",
      "restrictions": null
    }
  ]
}