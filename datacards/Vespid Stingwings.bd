  ],
  "firefightPloys": [
    {
      "name": "Neutron Overload",
      "cpCost": 1,
      "description": "Augmented in some ineffable fashion by the rapid wing beats of the Vespids, their neutron weaponry can unleash horrific point‑blank energy blasts. success for a friendly VESPID STINGWING operative that’s shooting with a neutron weapon during an activation in which it’s moved or used FLY. If the target is within 4\" of it, inflict D3 additional damage."
    },
    {
      "name": "Vicious Venom",
      "cpCost": 1,
      "description": "Many Strains of Vespid produce various neurotoxins and inflammatory agents from their abdominal stingers, which can reduce victims to convulsing wrecks or anaphylactically bloat their flesh to bursting point. STINGWING operative (excluding OVERSIGHT DRONE) is fighting and you strike with a critical success. Inflict D3 additional damage."
    }
  ],
  "factionEquipment": [
    {
      "name": "Accelerant Stimulant",
      "epCost": 1,
      "description": "Though it bears long‑term risks of injury or dangerous fatigue, this stimulant sharpens the Vespids’ reactions and lends them haste in the heat of battle. Whenever a friendly VESPID STINGWING operative (excluding OVERSIGHT DRONE) performs the Charge or Dash action, it can move an additional 1\". If it uses FLY for this action, you can set it back up 1\" further away. NOTES:",
      "restrictions": null
    },
    {
      "name": "Aggression Stimulant",
      "epCost": 1,
      "description": "Should their Vespids look in danger of being overrun, a Shas’ui may risk triggering the release of this highly‑addictive mixture of combat stimulants and aggression amplifiers. Whenever a friendly VESPID STINGWING operative (excluding OVERSIGHT DRONE) is fighting, its melee weapons have the Ceaseless weapon rule. NOTES:",
      "restrictions": null
    }
  ]
}